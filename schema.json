      "type": "string"
    },
    "sort reverse": {
      "type": "boolean"
    }
  },
  "allOf": [
    {
      "$comment": "Block compatibility guard: `subject` belongs to template/email-style blocks, not question blocks.",
      "if": {
        "required": [
          "question"
        ]
      },
      "then": {
        "not": {
          "required": [
            "subject"
          ]
        }
      }
    }
  ],
  "$defs": {
    "bootstrapColor": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "success",
        "danger",
        "warning",
        "info",
        "light",
        "link",
        "dark"
      ]
    },
    "languageCode": {
      "type": "string",
      "pattern": "^[a-z]{2,3}$",
      "$comment": "Lowercase ISO-639-1 or ISO-639-3 language code."
    },
    "needPrePostItem": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "pre": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "post": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "needSpecifier": {
      "$comment": "Matches documented `need` forms: string, list of variables, {pre/post}, or list items including {post} objects.",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/needPrePostItem"
        },
        {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/$defs/needPrePostItem"
              }
            ]
          }
        }
      ]
    },
    "attachmentLike": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "array",
          "items": {}
        }
      ]
    },
    "objects": {
      "$comment": "Objects must be a list or dict.",
      "anyOf": [
        {
          "type": "array",
          "items": {}
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "showIfFieldModifier": {
      "$comment": "Supports show-if forms: string shorthand, { variable, is }, or { code }.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "variable"
          ],
          "additionalProperties": false,
          "properties": {
            "variable": {
              "type": "string"
            },
            "is": {
              "type": [
                "string",
                "number",
                "boolean",
                "object",
                "array",
                "null"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "code"
          ],
          "additionalProperties": false,
          "properties": {
            "code": {
              "type": "string"
            }
          }
        }
      ]
    },
    "fieldItem": {
      "$comment": "A field descriptor item. Additional properties stay allowed because Docassemble permits label-style keys and arbitrary non-modifier field keys.",
