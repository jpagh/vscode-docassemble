    },
    "hide if": {
      "$ref": "#/$defs/showIfFieldModifier"
    },
    "js show if": {
      "type": "string",
      "$comment": "JavaScript expression; the Python validator also expects at least one val(\"...\") call"
    },
    "js hide if": {
      "type": "string",
      "$comment": "JavaScript expression; the Python validator also expects at least one val(\"...\") call"
    },
